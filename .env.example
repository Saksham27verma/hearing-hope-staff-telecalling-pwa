# CRM base URL (no trailing slash). Used by:
# - Local dev: Vite proxies POST /api/mobile-login → {VITE_CRM_URL}/api/mobile-login
# - Vercel: set CRM_BACKEND_URL (below) for the serverless proxy; VITE_CRM_URL is optional fallback on the server only.
VITE_CRM_URL=https://hearing-hope-crm.vercel.app

# Optional locally; required on Vercel for the serverless proxy (same value as VITE_CRM_URL is fine).
CRM_BACKEND_URL=https://hearing-hope-crm.vercel.app

# Same Firebase web config as the CRM / mobile app (Firebase Console → Project settings).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web Push (PWA notifications). Firebase Console → Project settings → Cloud Messaging → Web Push certificates → Generate key pair.
VITE_FIREBASE_VAPID_KEY=
